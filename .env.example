# ---------------------------------------------------------------------------
# Storyblok
# ---------------------------------------------------------------------------
# Space ID (Storyblok → Settings → General → Space ID). Currently unused at
# runtime but handy for webhook verification or Management API work later.
STORYBLOK_SPACE_ID=

# Public access token — read-only, published content only. Used by the server
# route (/api/story) that backs KV-cached reads in production.
STORYBLOK_PUBLIC_TOKEN=

# Preview access token — can read drafts. Used by @storyblok/nuxt on the
# client so the visual-editor bridge can show in-flight edits live.
STORYBLOK_PREVIEW_TOKEN=

# Shared secret for /api/storyblok/webhook. If set, Storyblok must include
# ?secret=<this> on the webhook URL; otherwise the handler rejects the call.
STORYBLOK_WEBHOOK_SECRET=

# Personal Management API token. Only needed for `npm run storyblok:push`
# (which creates/updates the slide component schemas in your space). Account
# settings → Personal access tokens → Generate new token. Treat like a
# password — don't commit the real value.
STORYBLOK_MANAGEMENT_TOKEN=

# ---------------------------------------------------------------------------
# Firebase (client SDK — these values ship in the browser bundle regardless)
# ---------------------------------------------------------------------------
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
