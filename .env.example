# Storyblok
STORYBLOK_TOKEN=your_preview_token_here
# Optional: shared secret for the /api/storyblok/webhook endpoint.
# If set, Storyblok must include ?secret=<this> on the webhook URL.
STORYBLOK_WEBHOOK_SECRET=

# Firebase (client SDK — these ship in the browser bundle)
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
